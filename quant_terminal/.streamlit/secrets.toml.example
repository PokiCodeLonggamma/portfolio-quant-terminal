# Streamlit Cloud secrets template
# ---------------------------------
# On Streamlit Cloud: App settings → Secrets → paste content (without the .example).
# Locally: copy to .streamlit/secrets.toml (gitignored). The app falls back to
# os.environ when these aren't set, so you can also use a `.env` file locally.

# --- Alpaca (live data + paper trading) ---
APCA_API_KEY_ID = ""
APCA_API_SECRET_KEY = ""
APCA_API_BASE_URL = "https://paper-api.alpaca.markets"

# --- SEC EDGAR (Form 4, 13F, SHO threshold list) ---
SEC_EMAIL = "you@example.com"

# --- FRED (macro series) ---
FRED_API_KEY = ""

# --- Financial Modeling Prep (earnings, fundamentals — optional) ---
FMP_API_KEY = ""

# --- Anthropic (transcript LLM summariser — optional) ---
ANTHROPIC_API_KEY = ""
ANTHROPIC_MODEL = "claude-sonnet-4-5"

# --- Alerts dispatchers (optional — leave empty to disable) ---
DISCORD_WEBHOOK_URL = ""
TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""
ALERT_SMTP_HOST = ""
ALERT_SMTP_PORT = "587"
ALERT_SMTP_USER = ""
ALERT_SMTP_PASS = ""
ALERT_SMTP_FROM = ""
ALERT_SMTP_TO = ""

# --- Execution (paper only by default — never set to 1 on Streamlit Cloud) ---
EXECUTION_ALLOW_LIVE = "0"
