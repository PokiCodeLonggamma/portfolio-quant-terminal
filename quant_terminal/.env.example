# ============================================================================
# Quant Terminal -- environment variables
# Copy to .env and fill in. Never commit .env to git.
# ============================================================================

# --- Alpaca (primary US equities data) ---
APCA_API_KEY_ID=your_alpaca_key_id_here
APCA_API_SECRET_KEY=your_alpaca_secret_key_here
# Paper endpoint by default; switch to https://api.alpaca.markets for live data.
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# --- SEC EDGAR scraper (Short Squeeze module) ---
# SEC requires a contact email in the User-Agent string.
SEC_EMAIL=your_email@example.com

# --- FRED (macro series for Macro Dashboard) ---
FRED_API_KEY=

# --- Financial Modeling Prep (optional secondary fallback) ---
FMP_API_KEY=

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# --- Logging ---
LOG_LEVEL=INFO
