# ============================================================================
# Quant Terminal -- environment variables
# Copy to .env and fill in. Never commit .env to git.
# ============================================================================

# --- Alpaca (primary US equities data) ---
APCA_API_KEY_ID=your_alpaca_key_id_here
APCA_API_SECRET_KEY=your_alpaca_secret_key_here
# Paper endpoint by default; switch to https://api.alpaca.markets for live data.
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# --- SEC EDGAR scraper (Short Squeeze module) ---
# SEC requires a contact email in the User-Agent string.
SEC_EMAIL=your_email@example.com

# --- FRED (macro series for Macro Dashboard) ---
FRED_API_KEY=

# --- Financial Modeling Prep (optional secondary fallback) ---
FMP_API_KEY=

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# --- LLM (Feature 14 — earnings transcript summary, news burst summary) ---
# Anthropic API key. Required for transcript summarisation + LLM news burst.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Execution / OMS (Feature 1) ---
# Paper mode is the default. Set to 1 to allow live trading — AND switch
# APCA_API_BASE_URL above to https://api.alpaca.markets. Any single guard
# missing → broker forces paper.
EXECUTION_ALLOW_LIVE=0

# --- Logging ---
LOG_LEVEL=INFO

# --- Alerts channels (Feature 2) ---
# Discord webhook URL (Server Settings → Integrations → Webhooks → New)
DISCORD_WEBHOOK_URL=

# Telegram bot (BotFather → /newbot → token, then /start the bot and read chat_id from
# https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP email (Gmail: enable 2FA + app password)
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_FROM=
ALERT_SMTP_TO=
